<div id="validador-seccion" style="background: #f4f4f4; padding: 20px; border-radius: 8px; text-align: center;">
    <h4>Verificación de Cuenta</h4>
    <p style="font-size: 12px; color: #666;">Ingresa tu ID para confirmar tu nombre antes de pagar</p>
    
    <input type="text" id="idJugador" placeholder="Ej: 12345678" 
           style="padding: 10px; width: 80%; border: 1px solid #ccc; border-radius: 5px;">
    
    <button id="btnConsultar" onclick="llamarAPI()" 
            style="margin-top: 10px; padding: 10px 20px; background: #e74c3c; color: white; border: none; border-radius: 5px; cursor: pointer; width: 85%;">
        VERIFICAR ID
    </button>

    <div id="resultado" style="margin-top: 15px; font-weight: bold; min-height: 20px;"></div>
</div>

<script>
async function llamarAPI() {
    const id = document.getElementById('idJugador').value;
    const resDiv = document.getElementById('resultado');
    const btn = document.getElementById('btnConsultar');

    if (!id) {
        resDiv.innerText = "⚠️ Por favor ingresa un ID";
        resDiv.style.color = "orange";
        return;
    }

    // Bloquear botón y mostrar carga
    btn.disabled = true;
    btn.innerText = "BUSCANDO...";
    resDiv.innerText = "Conectando con el servidor...";
    resDiv.style.color = "#555";

    try {
        // USAMOS TU URL DE RENDER
        const response = await fetch(`https://api-ff-hwre.onrender.com/check?id=${id}`);
        const data = await response.json();

        if (data.success) {
            resDiv.innerText = "✅ JUGADOR: " + data.nombre;
            resDiv.style.color = "green";
        } else {
            resDiv.innerText = "❌ ID no encontrado o error";
            resDiv.style.color = "red";
        }
    } catch (error) {
        resDiv.innerText = "🔌 Error de conexión (La API está despertando...)";
        resDiv.style.color = "red";
    } finally {
        btn.disabled = false;
        btn.innerText = "VERIFICAR ID";
    }
}
</script>
